# ArmorIQ SDK Configuration

# Required: Your API key from platform.armoriq.ai
ARMORIQ_API_KEY=ak_test_your_key_here

# Required: User and agent identifiers
USER_ID=your-user-id
AGENT_ID=your-agent-id

# Optional: Context identifier (default: "default")
CONTEXT_ID=default

# Optional: Environment mode (production or development)
ARMORIQ_ENV=development

# Optional: Override service endpoints
# IAP_ENDPOINT=https://customer-iap.armoriq.ai
# PROXY_ENDPOINT=https://customer-proxy.armoriq.ai
# BACKEND_ENDPOINT=https://customer-api.armoriq.ai

# Optional: MCP-specific proxy endpoints
# WEATHER_MCP_PROXY_URL=https://weather-proxy.example.com
# FINANCE_MCP_PROXY_URL=https://finance-proxy.example.com
